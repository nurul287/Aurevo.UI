# =============================================================================
# Aurevo.UI — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend REST API
# All data, auth, and file uploads go through Aurevo.BE.
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api
# Production: set to your Railway URL
# VITE_API_URL=https://your-service.up.railway.app/api

# -----------------------------------------------------------------------------
# Supabase — OAuth only (Google / Facebook sign-in)
# Not needed if you only use email/password auth.
# Dashboard → Settings → API → Project URL + anon (publishable) key.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Facebook Messenger (floating chat button)
# Page ID: from your m.me link — https://m.me/123456 → use 123456
# -----------------------------------------------------------------------------
VITE_FACEBOOK_PAGE_ID=855862097613203

# -----------------------------------------------------------------------------
# Meta Pixel (Facebook / Instagram ads & remarketing)
# Events Manager → Data sources → your Pixel → Settings → Pixel ID
# -----------------------------------------------------------------------------
VITE_META_PIXEL_ID=1409609890385063
