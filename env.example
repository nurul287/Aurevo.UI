# =============================================================================
# Aurevo — environment template (copy to .env.local, never commit real values)
# =============================================================================
# The Vite app only uses the two VITE_* variables below.
# Use LOCAL values when Docker Supabase is running (`pnpm db:start`).
# Use CLOUD values when pointing at your hosted project (dev/staging/prod).

# -----------------------------------------------------------------------------
# Option A — Local Supabase (Docker)
# -----------------------------------------------------------------------------
# Run: pnpm db:start  then  pnpm db:status
#
# URL: use "Project URL" / API base (always this port unless you changed config):
VITE_SUPABASE_URL=http://127.0.0.1:54321
#
# Anon key: copy exactly from `pnpm db:status` — format depends on CLI version:
#   • Newer local stack: "Publishable" key (starts with sb_publishable_)
#   • Older stack: "anon" JWT (three dot-separated segments)
# Do not use the "Secret" / service_role key in the browser app.
#
VITE_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME_FROM_DB_STATUS

# -----------------------------------------------------------------------------
# Option B — Hosted Supabase (cloud dev / staging / prod UI build)
# -----------------------------------------------------------------------------
# Dashboard → Settings → API
#
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Facebook Messenger (floating button → opens m.me chat with your Page)
# -----------------------------------------------------------------------------
# Page ID: from your m.me link — https://m.me/123456 → use 123456
# Meta deprecated the old on-site chat plugin; only the Page ID is required.
#
# VITE_FACEBOOK_PAGE_ID=123456

# -----------------------------------------------------------------------------
# Supabase CLI only (shell / CI — not read by Vite)
# -----------------------------------------------------------------------------
# For `pnpm db:link` and `pnpm db:push` against a remote project:
# SUPABASE_ACCESS_TOKEN=   # https://supabase.com/dashboard/account/tokens
# SUPABASE_DB_PROJECT_ID=  # project ref, not the full URL

# ----------------------------------------------------------------------------- Prod → local sync (optional; requires pg_dump / psql on PATH)
# ----------------------------------------------------------------------------- See supabase/README.md — "Copy production data + images".
# After `pnpm db:start` + `pnpm db:reset`, set production URI and run:
#   pnpm db:sync-from-prod     # dump prod + wipe local catalog + restore (recommended)
#   pnpm db:dump-prod
#   pnpm db:restore-local
#
# SYNC_PROD_DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# SYNC_LOCAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# SYNC_DUMP_FILE=supabase/manual/prod-data-snapshot.sql
