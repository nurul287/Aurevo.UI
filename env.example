# =============================================================================
# Aurevo.UI — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend REST API
# All data, auth, and file uploads go through Aurevo.BE — not Supabase directly.
# -----------------------------------------------------------------------------
# Local dev: Aurevo.BE running on http://localhost:5000
VITE_API_URL=http://localhost:5000/api
# Production: set to your Railway URL
# VITE_API_URL=https://your-service.up.railway.app/api

# -----------------------------------------------------------------------------
# Supabase — OAuth only (Google / Facebook sign-in)
# Email/password auth is handled by Aurevo.BE. Supabase SDK is kept only for
# the OAuth redirect flow (signInWithOAuth). autoRefreshToken and persistSession
# are disabled — tokens are stored in localStorage by Aurevo.BE.
# -----------------------------------------------------------------------------

# Option A — Local Supabase Docker (run `pnpm db:start` from Aurevo.BE)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd6aMy_JLDkV5bHnj1M72PsjeH71zWME

# Option B — Hosted Supabase (production / staging)
# Dashboard → Settings → API → Project URL + anon key (publishable)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Facebook Messenger (optional — floating chat button)
# Page ID: from your m.me link — https://m.me/123456 → use 123456
# -----------------------------------------------------------------------------
# VITE_FACEBOOK_PAGE_ID=123456

# -----------------------------------------------------------------------------
# Meta Pixel (optional — Facebook / Instagram ads & remarketing)
# Events Manager → Data sources → your Pixel → Settings → Pixel ID
# Omit in local dev to avoid test events in Meta.
# -----------------------------------------------------------------------------
# VITE_META_PIXEL_ID=1234567890123456
