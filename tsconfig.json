{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    // TS 6.0 stopped auto-including every package under node_modules/@types
    // (previously implicit) — e2e/*.ts and playwright.config.ts use Node
    // globals (process.env etc.), so restore @types/node explicitly.
    "types": ["node"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "e2e", "playwright.config.ts"],
  "exclude": ["src/components/button-showcase.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
